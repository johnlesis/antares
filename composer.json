{
    "name": "fatjon-lleshi/antares",
    "description": "Lightweight API first PHP framework for PHP 8.2+",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Fatjon Lleshi",
            "email": "johnlesis91@gmail.com"
        }
    ],
    "keywords": ["framework", "api", "rest", "php", "http", "psr-7", "dependency-injection"],
    "homepage": "https://github.com/johnlesis/antares",
    "support": {
        "issues": "https://github.com/johnlesis/antares/issues",
        "source": "https://github.com/johnlesis/antares"
    },
    "require": {
        "php": ">=8.2",
        "fatjon-lleshi/antares-validation": "^0.1.0",
        "fatjon-lleshi/antares-container": "^0.1.0",
        "fatjon-lleshi/antares-router": "^0.1.0",
        "nyholm/psr7": "^1.8",
        "nyholm/psr7-server": "^1.1",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "Antares\\": "src/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0"
    },
    "bin": ["bin/antares"]
}